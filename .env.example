# ─────────────────────────────────────────────────────────────────────────────
# Single shared environment file for BOTH the backend and the frontend.
# Copy to .env and fill in real values:  cp .env.example .env
#
# Loaded by:
#   • backend  → backend/src/config/index.js (dotenv, from this root path)
#   • frontend → Vite (envDir points here; ONLY VITE_-prefixed vars are exposed
#                to the browser bundle — backend secrets stay server-side).
#
# Every variable is required at startup (each app fails fast with a clear error
# if any are missing), except where noted. No environment-specific value is
# hardcoded in source. NEVER prefix a secret with VITE_ (that would expose it).
# ─────────────────────────────────────────────────────────────────────────────

# ═══ BACKEND ═════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Origin of the frontend (always allowed by CORS). Vite dev defaults to 5173.
CLIENT_URL=http://localhost:5173
# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────
# Include a database name (e.g. /healthcareDB). For local dev without Atlas,
# leave blank and run: npm run dev:memory
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/healthcareDB

# ─── Auth (Clerk) ─────────────────────────────────────────
# From https://dashboard.clerk.com → API keys. CLERK_PUBLISHABLE_KEY must equal
# VITE_CLERK_PUBLISHABLE_KEY below.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ─── LLM provider ─────────────────────────────────────────
# AVAILABLE_MODELS is "id" or "id:Human Label", comma-separated; DEFAULT_MODEL
# must be one of its ids. GROQ_API_KEY is required only when NODE_ENV=production;
# otherwise the AI layer uses safe built-in fallback replies.
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
DEFAULT_MODEL=llama-3.3-70b-versatile
AVAILABLE_MODELS=llama-3.1-8b-instant:Llama 3.1 8B,llama-3.3-70b-versatile:Llama 3.3 70B,openai/gpt-oss-120b:GPT-OSS 120B,openai/gpt-oss-20b:GPT-OSS 20B,openai/gpt-oss-safeguard-20b:GPT-OSS Safeguard 20B,qwen/qwen3-32b:Qwen 3 32B,groq/compound:Groq Compound,groq/compound-mini:Groq Compound Mini

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated extra origins, and wildcard host suffixes (e.g. preview deploys).
CORS_ORIGINS=
CORS_ALLOWED_ORIGIN_SUFFIXES=.netlify.app

# ═══ FRONTEND (Vite — only VITE_-prefixed vars reach the browser) ════════════

VITE_API_URL=http://localhost:3001
VITE_APP_ENV=development
# Must equal CLERK_PUBLISHABLE_KEY above.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
VITE_LLM_PROVIDER=groq
VITE_DEFAULT_MODEL=llama-3.3-70b-versatile
VITE_AVAILABLE_MODELS=llama-3.1-8b-instant:Llama 3.1 8B,llama-3.3-70b-versatile:Llama 3.3 70B,openai/gpt-oss-120b:GPT-OSS 120B,openai/gpt-oss-20b:GPT-OSS 20B,openai/gpt-oss-safeguard-20b:GPT-OSS Safeguard 20B,qwen/qwen3-32b:Qwen 3 32B,groq/compound:Groq Compound,groq/compound-mini:Groq Compound Mini
# Optional: Vite dev-server port (Vite default when unset).
# VITE_DEV_PORT=5173
