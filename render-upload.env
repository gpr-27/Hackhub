# ═════════════════════════════════════════════════════════════════════════════
#  render-upload.env — every key the Aura Render Blueprint (render.yaml) needs
# ═════════════════════════════════════════════════════════════════════════════
#  This file mirrors render.yaml 1:1. Use it as your fill-in sheet for deploying
#  the Docker Blueprint (one Render web service that builds the SPA and runs the
#  Express API, serving both from one URL — no CORS, no second service).
#
#  DEPLOY
#    1. Render Dashboard → New → Blueprint → pick the repo (gpr-27/Hackhub).
#    2. Render reads render.yaml and PROMPTS for the 4 `sync: false` SECRETS at
#       the bottom of this file. Paste your real SANDBOX/TEST values → Apply.
#       (The PUBLIC keys above the line are already baked into render.yaml — you
#        don't enter those; they're listed here only so you can see the full set.)
#    3. First build takes a few minutes. When live, open the URL and confirm
#       …/api/health returns 200.
#
#  Alternatively (no Blueprint): Service → Environment → "Add from .env" → paste
#  this whole file, then fill the 4 placeholders.
#
#  This file is committed as a PLACEHOLDER template (no real secrets). Put your
#  REAL values into Render's Blueprint prompts / dashboard — do NOT paste real
#  secrets back into this committed file and push them.
# ─────────────────────────────────────────────────────────────────────────────

# ═══ PUBLIC — already set by render.yaml (shown for reference) ════════════════
NODE_ENV=production
LOG_LEVEL=info
LLM_PROVIDER=groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
DEFAULT_MODEL=llama-3.3-70b-versatile
AVAILABLE_MODELS=llama-3.1-8b-instant:Llama 3.1 8B,llama-3.3-70b-versatile:Llama 3.3 70B,openai/gpt-oss-120b:GPT-OSS 120B,openai/gpt-oss-20b:GPT-OSS 20B,openai/gpt-oss-safeguard-20b:GPT-OSS Safeguard 20B,qwen/qwen3-32b:Qwen 3 32B,groq/compound:Groq Compound,groq/compound-mini:Groq Compound Mini

# ═══ SECRETS — render.yaml has these as `sync: false`; YOU provide them ═══════
# Render prompts for exactly these four on first Blueprint apply.

# MongoDB Atlas (free M0): https://www.mongodb.com/atlas → create cluster →
# Connect → Drivers → copy the SRV string. Include a db name (/healthcareDB) and
# URL-encode special characters in the password. Network Access must allow Render
# (simplest: allow 0.0.0.0/0).
MONGODB_URI=<REPLACE_mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/healthcareDB>

# Clerk (test instance): https://dashboard.clerk.com → API keys.
# The publishable key (pk_test_…) is public and is ALSO baked into the SPA at
# build time (render.yaml/Dockerfile map it to VITE_CLERK_PUBLISHABLE_KEY).
CLERK_PUBLISHABLE_KEY=<REPLACE_pk_test_xxx>
CLERK_SECRET_KEY=<REPLACE_sk_test_xxx>

# Groq (free): https://console.groq.com → API Keys → create key (starts gsk_).
GROQ_API_KEY=<REPLACE_gsk_xxx>
